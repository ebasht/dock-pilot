# Copy to .env on VPS:  cp .env.dock-pilot.example .env && chmod 600 .env
# PostgreSQL runs in Docker (image dock-pilot-postgres:latest from the release bundle).

POSTGRES_USER=dockpilot
POSTGRES_PASSWORD=change-me-strong-postgres-password
POSTGRES_DB=dockpilot
POSTGRES_IMAGE=dock-pilot-postgres:latest

DATABASE_URL=postgres://dockpilot:change-me-strong-postgres-password@postgres:5432/dockpilot?sslmode=disable

HTTP_ADDR=:8080
SECRETS_ENCRYPTION_KEY=change-me-to-32-byte-key-here!!
API_TOKEN=change-me-long-api-token-here

PANEL_DOMAIN=deploy.example.com
CORS_ALLOWED_ORIGINS=https://deploy.example.com

DEPLOY_MODE=real
DEPLOY_WORK_DIR=/var/lib/dock-pilot
HOST_ROOT=/host
NGINX_SITES_AVAILABLE=/host/etc/nginx/sites-available
NGINX_SITES_ENABLED=/host/etc/nginx/sites-enabled
CERTBOT_EMAIL=admin@example.com

# Optional: outbound proxy if api.telegram.org is blocked on the VPS (Russia, etc.)
# In the panel you can use the same SOCKS as host-network bots: socks5://127.0.0.1:1080
# (compose service telegram-socks-relay forwards it for the API container).
# TELEGRAM_HTTP_PROXY=socks5://127.0.0.1:1080
# TELEGRAM_SOCKS_RELAY_BIND=172.17.0.1
# TELEGRAM_SOCKS_RELAY_PORT=1081
# TELEGRAM_SOCKS_UPSTREAM=127.0.0.1:1080

API_PORT=8080
FRONTEND_PORT=3000

API_IMAGE=dock-pilot-api:latest
FRONTEND_IMAGE=dock-pilot-frontend:latest
MIGRATE_IMAGE=dock-pilot-migrate:latest
