# PostgreSQL (Docker)
POSTGRES_PORT=5432

# Backend (connects to Postgres on localhost)
DATABASE_URL=postgres://dockpilot:dockpilot@localhost:5432/dockpilot?sslmode=disable
HTTP_ADDR=:8080
SECRETS_ENCRYPTION_KEY=change-me-to-32-byte-key-here!!

# API auth (same value on backend and frontend)
API_TOKEN=dev-local-token-change-me!!

# Frontend (baked into Docker image at build; local dev uses .env.local)
NEXT_PUBLIC_API_URL=http://localhost:8080

# Backend CORS (comma-separated UI origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Deployment: stub locally, real on VPS (needs Docker socket + nginx + certbot on host)
DEPLOY_MODE=stub
DEPLOY_WORK_DIR=/var/lib/dock-pilot
# CERTBOT_EMAIL=dev@localhost.local
# API token is entered in the browser on first visit (not stored in the image)

# Docker image names (optional)
# API_IMAGE=dock-pilot-api:latest
# FRONTEND_IMAGE=dock-pilot-frontend:latest

# Target OS/arch for VPS images (default: linux/amd64; on Mac M1/M2 use this for typical VPS)
# DOCKER_PLATFORM=linux/amd64
